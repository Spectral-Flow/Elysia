{
  "version": 2,
  "buildCommand": "cd frontend && npm ci && npm run build",
  "outputDirectory": "frontend/build",
  "installCommand": "echo 'No root dependencies to install'",
  "functions": {
    "api/*.py": {
      "runtime": "python3.9"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ],
  "env": {
    "OPENAI_API_KEY": "@OPENAI_API_KEY",
    "JWT_SECRET_KEY": "@jwt_secret_key", 
    "SECRET_KEY": "@secret_key",
    "BUILDING_NAME": "The Avant",
    "BUILDING_ADDRESS": "6333 Greenwood Plaza Blvd, Centennial, CO 80111",
    "BUILDING_CONTACT": "tel:888-220-1596"
  }
}
